# Flask 配置
FLASK_SECRET_KEY=dev-secret-key-change-in-production
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# BSHT 账号配置
BSHT_USERNAME=your_username
BSHT_PASSWORD=your_password
DEFAULT_CHANNEL_ID=28951
DEFAULT_CHANNEL_PASSCODE=0

# 数据库配置
DATABASE_PATH=audio.db
RECORDINGS_PATH=recordings
RECORDINGS_RETENTION_DAYS=0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=bot_web.log

# STT/TTS 服务（可选）
STT_SERVICE_URL=
STT_API_KEY=
TTS_SERVICE_URL=
TTS_API_KEY=

# 通知服务（可选）
NOTIFICATION_SERVICE_URL=
NOTIFICATION_API_KEY=
