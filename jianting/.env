# BSHT账号配置
BSHT_USERNAME=your_username
BSHT_PASSWORD=your_password
BSHT_CHANNEL_ID=28951
BSHT_CHANNEL_PASSCODE=0

# SiliconFlow API配置
SILICONFLOW_API_KEY=your-api-key-here

# DSP配置
DSP_ENABLED=true
DSP_ALGORITHM=timedomain
DSP_AGC_MODE=webrtc
DSP_SNR_THRESHOLD_HIGH=20
DSP_SNR_THRESHOLD_LOW=10

# 数据库配置
DATABASE_PATH=data/records.db
DATABASE_MAX_RECORDS=10000
