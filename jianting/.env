EXPERT_MODEL_ENABLED=true

# ========== DSP 配置 ==========
DSP_ENABLED=true                    # 是否启用DSP
DSP_MIN_RMS_DB=-50.0               # 最小音频电平(dB)，低于此值视为无效音频
DSP_MIN_DURATION=0.3               # 最小音频时长(秒)，低于此值视为无效音频
DSP_ALWAYS_ON=true                  # 是否始终启用DSP（全部降噪）
DSP_DUAL_MODE=false                 # 对比模式：同时识别原始音频和降噪音频

DATABASE_PATH=data/records.db
DATABASE_MAX_RECORDS=10000
LOG_LEVEL=INFO
# ========== 微信推送配置 ==========
# WXPUSH_URL: 推送服务地址
# WXPUSH_TOKEN: 推送服务 Token
# WXPUSH_TARGETS: 推送目标，格式: userid:名称:关键词1,关键词2
#   - 关键词为空表示接收所有消息
#   - 多个目标用分号分隔
# 示例: WXPUSH_TARGETS=oxxxxx1:张三:CQ,呼号;oxxxxx2:李四
