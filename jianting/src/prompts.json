{
    "version": "2.4.1",
    "description": "业余无线电(HAM)通联识别 - 优化版",
    "expert_analysis": {
        "system_prompt": "你是一名热心的业余无线电助手。你的目标是**尽可能多地提取有效信息**。即使ASR文本包含大量噪音、断字或奇怪的翻译，也不要轻易放弃。请忽略干扰项，尽力还原对话。",
        "correction_rules": {
            "common_mistakes": [
                {"from": "CQCQ", "to": "CQ", "reason": "CQ连写"},
                {"from": "柴友", "to": "台友", "reason": "台友误识别"},
                {"from": "财友", "to": "台友", "reason": "台友误识别"},
                {"from": "菜油", "to": "台友", "reason": "台友误识别"},
                {"from": "超收", "to": "抄收", "reason": "抄收误识别"},
                {"from": "抄手", "to": "抄收", "reason": "抄收误识别"},
                {"from": "起皮", "to": "起皮", "reason": "保留HAM术语"},
                {"from": "背噪", "to": "背噪", "reason": "保留HAM术语"},
                {"from": "苗子", "to": "苗子", "reason": "保留HAM术语"},
                {"from": "棒子", "to": "棒子", "reason": "保留HAM术语"},
                {"from": "手台", "to": "手台", "reason": "保留HAM术语"},
                {"from": "八木", "to": "八木", "reason": "保留HAM术语"}
            ],
            "number_mappings": {
                "洞": "0",
                "冬": "0",
                "栋": "0",
                "动": "0",
                "幺": "1",
                "妖": "1",
                "腰": "1",
                "两": "2",
                "二": "2",
                "三": "3",
                "山": "3",
                "四": "4",
                "思": "4",
                "五": "5",
                "无": "5",
                "六": "6",
                "陆": "6",
                "量": "6",
                "大": "6",
                "拐": "7",
                "七": "7",
                "起": "7",
                "八": "8",
                "八": "8",
                "勾": "9",
                "九": "9",
                "狗": "9"
            }
        },
        "alphabet_mappings": {
            "alpha": "A",
            "alfa": "A",
            "bravo": "B",
            "charlie": "C",
            "delta": "D",
            "echo": "E",
            "foxtrot": "F",
            "golf": "G",
            "hotel": "H",
            "india": "I",
            "juliett": "J",
            "juliet": "J",
            "kilo": "K",
            "lima": "L",
            "mike": "M",
            "november": "N",
            "oscar": "O",
            "papa": "P",
            "quebec": "Q",
            "romeo": "R",
            "sierra": "S",
            "tango": "T",
            "uniform": "U",
            "victor": "V",
            "whiskey": "W",
            "whisky": "W",
            "xray": "X",
            "x-ray": "X",
            "yankee": "Y",
            "zulu": "Z"
        },
        "noise_filter": {
            "remove_patterns": [
                "subtitle",
                "subtitles",
                "caption",
                "captions",
                "copyright",
                "thank you",
                "thanks for watching",
                "谢谢观看",
                "字幕",
                "由",
                "网易",
                "音乐"
            ],
            "keep_if_has_content": true
        },
        "extraction": {
            "callsign_priority": "优先提取'这里是'后面的呼号，其次提取'BD/BG/BH/BI'开头的呼号",
            "rst_keywords": ["59", "59+", "五九", "信号", "不起皮", "听不清"],
            "qth_keywords": ["PM", "grid", "在", "这里", "山上", "车里", "家里"],
            "rig_keywords": ["7300", "7100", "7000", "设备", "天线", "棒子", "八木", "手台", "苗子"]
        },
        "signal_type_rules": [
            {"code": "CQ", "logic": "包含CQ呼叫，或疑似广泛呼叫"},
            {"code": "QSO", "logic": "包含信号报告(59)或双方对话"},
            {"code": "CQ73", "logic": "包含73祝福"},
            {"code": "QRZ", "logic": "包含QRZ或询问谁在"},
            {"code": "NOISE", "logic": "只有噪音词，无有效内容"},
            {"code": "UNKNOWN", "logic": "有内容但无法确定"}
        ],
        "output_format": {
            "signal_type": "CQ/QSO/CQ73/QRZ/NOISE/UNKNOWN",
            "content_normalized": "规范化后的文本",
            "user_id": "提取的呼号",
            "extracted_info": {"rst": "信号报告", "qth": "位置", "rig": "设备"},
            "signal_quality": "1-9",
            "confidence": "0.0-1.0"
        },
        "user_prompt_template": "ASR原始文本: \"{asr_text}\"\n\n请按以下步骤处理：\n1. 清洗：删除无意义词(thank you, subtitle等)\n2. 修正：'柴友'→'台友'，'超收'→'抄收'\n3. 提取：尽力找呼号、信号报告(59)、位置、设备\n4. 输出JSON"
    },
    "asr_prompt": "你是HAM语音识别助手。请忽略背景噪音，尽力识别所有中文对话、字母(Alpha/CQ等)和数字。直接输出文字，不要其他内容。"
}